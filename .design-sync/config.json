    "PlaylistDock": { "skip": ["components-audio-playlistdock--seeded"] },
    "Card": { "skip": ["components-lists-card--default", "components-lists-card--highlighted", "components-lists-card--loading", "components-lists-card--disabled"] },
    "CardGrid": { "skip": ["components-lists-cardgrid--default", "components-lists-cardgrid--with-search"] }
