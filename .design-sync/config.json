{
  "projectId": "7888d2e2-9907-4930-9b2c-24a6b4ac3aea",
  "shape": "storybook",
  "pkg": "magic-worlds",
  "globalName": "Reverie",
  "tsconfig": "../tsconfig.paths.json",
  "storybookConfigDir": ".design-sync/sb-config",
  "storybookStatic": ".design-sync/sb-reference",
  "cssEntry": "reverie-compiled.css",
  "readmeHeader": ".design-sync/conventions.md",
  "provider": { "component": "ReveriePreviewProvider" },
  "storyImports": { "loaders": { ".webp": "dataurl", ".png": "dataurl" } },
