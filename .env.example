# magic-worlds SPA — Vite env. Copy to .env and adjust for your machine.
# Only VITE_-prefixed vars are exposed to the browser (see src/infrastructure/api/baseUrl.ts).

# REQUIRED — base URL of the magic-worlds-api BFF (NOT api.auth directly).
# The BFF refresh cookie (mw_refresh_token) is HttpOnly + Secure + SameSite=None,
# so it works cross-site; every credentialed auth call sends credentials:'include'.
# Dev/LAN: SPA and BFF are same-site on different ports — `{hostname}` is replaced
# with the page's hostname at runtime, so one value works everywhere:
#   page http://localhost:5173    -> API http://localhost:8010
#   page http://192.168.1.13:5173 -> API http://192.168.1.13:8010
# Production: use the BFF's absolute HTTPS URL (e.g. https://api-magic-worlds.arz.ai).
# An HTTPS page cannot call an HTTP API (mixed content blocks every auth call), and
# SameSite=None requires Secure. NOTE: a cross-site cookie is third-party, which
# Safari/Firefox block — for those, host the SPA and BFF on one registrable domain.
VITE_API_BASE_URL=http://{hostname}:8010

# --- Frontend feature flags --------------------------------------------------
# All are default-off: only the exact string `true` enables the feature.
# Chatroom and 1:1 character chat remain available without a flag.
VITE_FEATURE_COMMUNITY_CARDS_ENABLED=false
VITE_FEATURE_LOREBOOKS_ENABLED=false
VITE_FEATURE_LOREBOOK_RESOURCES_ENABLED=false
VITE_FEATURE_VOICES_ENABLED=false
VITE_FEATURE_CALLS_ENABLED=false
VITE_FEATURE_NOVELS_ENABLED=false
VITE_FEATURE_GROUP_CHATS_ENABLED=false

# --- Google sign-in ("Continue with Google") ---------------------------------
# NO extra SPA variable is required. The flow uses VITE_API_BASE_URL (it calls the
# BFF's /auth/provider-init/google, /auth/google/start/shim, /auth/google/exchange)
# and window.location.origin as the return origin. To enable it end to end, the
# SPA's actual origin (e.g. http://localhost:5173) MUST be listed in:
#   - the BFF's   PROVIDER_INIT_RETURN_ORIGINS  (and CORS_ORIGINS)
#   - api.auth's  GOOGLE_OAUTH_RETURN_ORIGINS
# and the BFF's FRONTEND_GOOGLE_RETURN_URL must point back at this origin.

# --- Billing (Stripe plans + credit packs) — frontend kill-switch ------------
# isBillingFeatureEnabled() gates the purchase UI: the "Plans & credits" button
# in Profile -> Membership and the #/billing checkout / buy / manage-subscription
# actions. Default false = OFF; the demonstrative plan tiers still show in
# Profile -> Membership (read-only) but nothing is purchasable, and no
# GET /billing/plans call fires. Server billing must ALSO be enabled (the
# `enabled` flag from GET /billing/plans) for purchases to actually appear.
# Credit usage, deductions, and promo-code / email-grant redemption work
# regardless of this flag. Stripe billing reconciliation is backend-only;
# configure the BFF's BILLING_* vars as needed — see docs/billing/SETUP.md.
VITE_BILLING_ENABLED=true

# --- Patreon — frontend kill-switch ------------------------------------------
# isPatreonFeatureEnabled() gates Patreon affordances and the Patreon apiService
# methods (they throw while off). No Patreon UI ships yet; this scaffolds future
# link/connect UI. Default false = OFF. Patreon entitlement reconciliation is
# backend-only; configure the BFF's PATREON_* vars as needed.
VITE_PATREON_ENABLED=true
