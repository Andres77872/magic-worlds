# magic-worlds SPA — Vite env. Copy to .env and adjust for your machine.
# Only VITE_-prefixed vars are exposed to the browser (see src/infrastructure/api/baseUrl.ts).

# REQUIRED — base URL of the magic-worlds-api BFF (NOT api.auth directly).
# The BFF refresh cookie (mw_refresh_token) is HttpOnly + SameSite=lax, so the API
# must be SAME-SITE with the page or the browser refuses to store/send it and every
# refresh 401s. `{hostname}` is replaced with the page's hostname at runtime, so one
# value works for both localhost and LAN-device access:
#   page http://localhost:5173    -> API http://localhost:8010
#   page http://192.168.1.13:5173 -> API http://192.168.1.13:8010
VITE_API_BASE_URL=http://{hostname}:8010

# Character voice calls (Groq STT + MiniMax TTS). isFrontendVoiceModeEnabled() is
# the kill-switch; set false to hide all call affordances.
VITE_VOICE_MODE_ENABLED=true

# --- Google sign-in ("Continue with Google") ---------------------------------
# NO extra SPA variable is required. The flow uses VITE_API_BASE_URL (it calls the
# BFF's /auth/provider-init/google, /auth/google/start/shim, /auth/google/exchange)
# and window.location.origin as the return origin. To enable it end to end, the
# SPA's actual origin (e.g. http://localhost:5173) MUST be listed in:
#   - the BFF's   PROVIDER_INIT_RETURN_ORIGINS  (and CORS_ORIGINS)
#   - api.auth's  GOOGLE_OAUTH_RETURN_ORIGINS
# and the BFF's FRONTEND_GOOGLE_RETURN_URL must point back at this origin.
